{
	"compilerOptions": {
		/* Visit https://aka.ms/tsconfig.json to read more about this file */

		/* Set the JavaScript language version for emitted JavaScript and include compatible library declarations. */
		"target": "es2021",
		/* Specify a set of bundled library declaration files that describe the target runtime environment. */
		"lib": ["es2021"],
		/* Specify what JSX code is generated. */
		"jsx": "react-jsx",

		/* Specify what module code is generated. */
		"module": "es2022",
		/* Specify how TypeScript looks up a file from a given module specifier. */
		"moduleResolution": "bundler",
		/* Specify type package names to be included without being referenced in a source file. */
		"types": ["./worker-configuration.d.ts", "node"],
		/* Enable importing .json files */
		"resolveJsonModule": true,

		/* Allow JavaScript files to be a part of your program. Use the `checkJS` option to get errors from these files. */
		"allowJs": true,
		/* Enable error reporting in type-checked JavaScript files. */
		"checkJs": false,

		/* Disable emitting files from a compilation. */
		"noEmit": true,

		/* Ensure that each file can be safely transpiled without relying on other imports. */
		"isolatedModules": true,
		/* Require type-only imports/exports to be marked explicitly (`import type`), emitting other imports verbatim. */
		"verbatimModuleSyntax": true,
		/* Allow 'import x from y' when a module doesn't have a default export. */
		"allowSyntheticDefaultImports": true,
		/* Ensure that casing is correct in imports. */
		"forceConsistentCasingInFileNames": true,

		/* Enable all strict type-checking options. */
		"strict": true,
		/* Add 'undefined' to index signature results for safer array/object access. */
		"noUncheckedIndexedAccess": true,
		/* Report errors on unused local variables. */
		"noUnusedLocals": true,
		/* Report errors on unused function parameters. */
		"noUnusedParameters": true,
		/* Ensure overriding members in derived classes are marked with an 'override' modifier. */
		"noImplicitOverride": true,
		/* Report errors for fallthrough cases in switch statements. */
		"noFallthroughCasesInSwitch": true,
		/* Report an error when not all code paths in a function return a value. */
		"noImplicitReturns": true,
		/* Require index-signature properties to be accessed with bracket notation. */
		"noPropertyAccessFromIndexSignature": true,
		/* Check that side-effect imports resolve to an existing module. */
		"noUncheckedSideEffectImports": true,
		/* Report errors on unreachable code. */
		"allowUnreachableCode": false,
		/* Report errors on unused labels. */
		"allowUnusedLabels": false,

		/* Skip type checking all .d.ts files. */
		"skipLibCheck": true
	}
}
